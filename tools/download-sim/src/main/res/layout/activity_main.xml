<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:text="@string/header"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_slow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_slow" />

        <Button
            android:id="@+id/btn_fast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_fast" />

        <Button
            android:id="@+id/btn_two"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_two" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/hint_interval"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_interval"
            android:inputType="number"
            android:text="1500" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/hint_step"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/step"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_step"
            android:inputType="number"
            android:text="2" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/hint_count"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_count"
            android:inputType="number"
            android:text="1" />

        <Button
            android:id="@+id/btn_custom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_custom" />
    </LinearLayout>
</ScrollView>
