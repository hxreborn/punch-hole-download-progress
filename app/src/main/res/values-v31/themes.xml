<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash theme: API 31+ uses dedicated SplashScreen attrs -->
    <style name="Theme.PHDP.Splash" parent="Theme.PHDP">
        <item name="android:windowSplashScreenBackground">@color/surface_dark</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_splash_animated</item>
        <item name="android:windowSplashScreenAnimationDuration">500</item>
        <item name="postSplashScreenTheme">@style/Theme.PHDP</item>
    </style>
</resources>
